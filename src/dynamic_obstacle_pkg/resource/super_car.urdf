<?xml version="1.0"?>
<robot name="super_car">
  <!-- Main Body -->
  <link name="base_link">
    <visual>
      <geometry><box size="4.5 2.0 1.0"/></geometry>
      <material name="silver"><color rgba="0.75 0.75 0.75 0.6"/></material>
    </visual>
  </link>

  <!-- Steering Links -->
  <link name="fl_steering_link"/><link name="fr_steering_link"/>

  <joint name="fl_steer_j" type="revolute">
    <parent link="base_link"/><child link="fl_steering_link"/>
    <origin xyz="1.5 0.8 0" rpy="0 0 0"/><axis xyz="0 0 1"/><limit lower="-0.6" upper="0.6" effort="100" velocity="10"/>
  </joint>
  <joint name="fr_steer_j" type="revolute">
    <parent link="base_link"/><child link="fr_steering_link"/>
    <origin xyz="1.5 -0.8 0" rpy="0 0 0"/><axis xyz="0 0 1"/><limit lower="-0.6" upper="0.6" effort="100" velocity="10"/>
  </joint>

  <!-- Wheels -->
  <link name="fl_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.4" length="0.3"/></geometry><material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
  </link>
  <joint name="fl_j" type="continuous">
    <parent link="fl_steering_link"/><child link="fl_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="fr_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.4" length="0.3"/></geometry><material name="black"/></visual>
  </link>
  <joint name="fr_j" type="continuous">
    <parent link="fr_steering_link"/><child link="fr_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="rl_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.4" length="0.3"/></geometry><material name="black"/></visual>
  </link>
  <joint name="rl_j" type="continuous">
    <parent link="base_link"/><child link="rl_wheel"/>
    <origin xyz="-1.5 0.8 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="rr_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.4" length="0.3"/></geometry><material name="black"/></visual>
  </link>
  <joint name="rr_j" type="continuous">
    <parent link="base_link"/><child link="rr_wheel"/>
    <origin xyz="-1.5 -0.8 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <!-- LiDAR -->
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.1" length="0.2"/></geometry><material name="red"><color rgba="0.8 0 0 1"/></material></visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/>
    <origin xyz="0 0 1.5" rpy="0 0 0"/>
  </joint>

</robot>
