<?xml version="1.0"?>
<robot name="super_car">
  <!-- Main Body: Silver SUV Mesh -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
        <mesh filename="https://fuel.gazebosim.org/1.0/openrobotics/models/suv/4/meshes/suv.obj" scale="0.06 0.06 0.06"/>
      </geometry>
      <material name="silver"><color rgba="0.75 0.75 0.75 0.8"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.5"/>
      <geometry><box size="4.5 2.2 1.2"/></geometry>
    </collision>
  </link>

  <!-- Steering Links -->
  <link name="fl_steering_link"/><link name="fr_steering_link"/>

  <joint name="fl_steer_j" type="revolute">
    <parent link="base_link"/><child link="fl_steering_link"/>
    <origin xyz="1.45 0.85 -0.1" rpy="0 0 0"/><axis xyz="0 0 1"/><limit lower="-0.6" upper="0.6" effort="100" velocity="10"/>
  </joint>
  <joint name="fr_steer_j" type="revolute">
    <parent link="base_link"/><child link="fr_steering_link"/>
    <origin xyz="1.45 -0.85 -0.1" rpy="0 0 0"/><axis xyz="0 0 1"/><limit lower="-0.6" upper="0.6" effort="100" velocity="10"/>
  </joint>

  <!-- Wheels: Positioned exactly in the fenders -->
  <link name="fl_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.38" length="0.3"/></geometry><material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
  </link>
  <joint name="fl_j" type="continuous">
    <parent link="fl_steering_link"/><child link="fl_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="fr_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.38" length="0.3"/></geometry><material name="black"/></visual>
  </link>
  <joint name="fr_j" type="continuous">
    <parent link="fr_steering_link"/><child link="fr_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="rl_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.4" length="0.3"/></geometry><material name="black"/></visual>
  </link>
  <joint name="rl_j" type="continuous">
    <parent link="base_link"/><child link="rl_wheel"/>
    <origin xyz="-1.45 0.85 -0.1" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="rr_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.4" length="0.3"/></geometry><material name="black"/></visual>
  </link>
  <joint name="rr_j" type="continuous">
    <parent link="base_link"/><child link="rr_wheel"/>
    <origin xyz="-1.45 -0.85 -0.1" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <!-- LiDAR: Placed on the roof -->
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.1" length="0.1"/></geometry><material name="red"><color rgba="0.8 0 0 1"/></material></visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/>
    <origin xyz="0 0 1.2" rpy="0 0 0"/>
  </joint>

</robot>
