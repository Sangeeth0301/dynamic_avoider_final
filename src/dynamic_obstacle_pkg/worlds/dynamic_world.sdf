<?xml version="1.0" ?>
<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  dynamic_world.sdf  —  Complete rewrite for ROS 2 Jazzy     ║
  ║                                                              ║
  ║  ROOT CAUSE FIXES in this file:                              ║
  ║  1. Actors were blinking because they had NO <animation>     ║
  ║     block — only <skin>. Gazebo Harmonic REQUIRES a separate ║
  ║     <animation> block that references the SAME .dae file.    ║
  ║     Without it the actor pose interpolates but the mesh      ║
  ║     stays at frame-0, causing the blink/snap effect.         ║
  ║  2. Actors only move front-back because the trajectory       ║
  ║     waypoints had identical Y coordinates. Fixed with proper ║
  ║     2-D paths that cross the robot's corridor.               ║
  ║  3. Car mesh used an ABSOLUTE path to /home/sangeeth/...     ║
  ║     which does not exist on other machines. Replaced with    ║
  ║     a plain box+cylinder visual that works everywhere.       ║
  ║  4. Car spawn pose was at (0,-12,0.401) but wheels have      ║
  ║     radius 0.4 m — correct spawn Z = 0.4 (wheel radius).    ║
  ║  5. AckermannSteering plugin: Nav2 sends geometry_msgs/Twist ║
  ║     with linear.x and angular.z. The Ackermann plugin        ║
  ║     receives this correctly — no change needed there.        ║
  ║  6. Lidar sensor type changed from "gpu_ray" to "gpu_lidar"  ║
  ║     which is the correct sensor type name in Gazebo Harmonic.║
  ║  7. Physics step size increased to 0.004 (250 Hz) — 0.001   ║
  ║     (1000 Hz) causes real_time_factor < 1 on most machines,  ║
  ║     which makes actors appear to slow down or jitter.        ║
  ╚══════════════════════════════════════════════════════════════╝
-->
<sdf version="1.8" xmlns:gz="http://gazebosim.org/schema">
  <world name="dynamic_obstacle_world">

    <!-- ═══════════ Physics ═══════════ -->
    <physics name="4ms" type="ignored">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- ═══════════ Required World Plugins ═══════════ -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ═══════════ Lighting ═══════════ -->
    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.8 1</diffuse>
      <specular>0.4 0.4 0.4 1</specular>
      <attenuation>
        <range>1000</range><constant>0.9</constant>
        <linear>0.01</linear><quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ═══════════ Scene ═══════════ -->
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.6 0.7 0.9 1</background>
      <shadows>false</shadows>
    </scene>

    <!-- ═══════════ Ground Plane ═══════════ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══════════ Arena Walls  30 × 30 m ═══════════ -->
    <model name="arena">
      <static>true</static>
      <link name="walls">
        <!-- North -->
        <collision name="cn"><pose>0 15 1.25 0 0 0</pose>
          <geometry><box><size>30 0.4 2.5</size></box></geometry></collision>
        <visual name="vn"><pose>0 15 1.25 0 0 0</pose>
          <geometry><box><size>30 0.4 2.5</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material></visual>
        <!-- South -->
        <collision name="cs"><pose>0 -15 1.25 0 0 0</pose>
          <geometry><box><size>30 0.4 2.5</size></box></geometry></collision>
        <visual name="vs"><pose>0 -15 1.25 0 0 0</pose>
          <geometry><box><size>30 0.4 2.5</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material></visual>
        <!-- East -->
        <collision name="ce"><pose>15 0 1.25 0 0 0</pose>
          <geometry><box><size>0.4 30 2.5</size></box></geometry></collision>
        <visual name="ve"><pose>15 0 1.25 0 0 0</pose>
          <geometry><box><size>0.4 30 2.5</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material></visual>
        <!-- West -->
        <collision name="cw"><pose>-15 0 1.25 0 0 0</pose>
          <geometry><box><size>0.4 30 2.5</size></box></geometry></collision>
        <visual name="vw"><pose>-15 0 1.25 0 0 0</pose>
          <geometry><box><size>0.4 30 2.5</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient></material></visual>
        <!-- 4 Pillars -->
        <collision name="cp1"><pose>6 6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="vp1"><pose>6 6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry>
          <material><ambient>0.7 0.2 0.2 1</ambient></material></visual>
        <collision name="cp2"><pose>-6 6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="vp2"><pose>-6 6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry>
          <material><ambient>0.7 0.2 0.2 1</ambient></material></visual>
        <collision name="cp3"><pose>6 -6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="vp3"><pose>6 -6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry>
          <material><ambient>0.7 0.2 0.2 1</ambient></material></visual>
        <collision name="cp4"><pose>-6 -6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="vp4"><pose>-6 -6 1.25 0 0 0</pose>
          <geometry><cylinder><radius>0.6</radius><length>2.5</length></cylinder></geometry>
          <material><ambient>0.7 0.2 0.2 1</ambient></material></visual>
      </link>
    </model>

    <!-- ═══════════ THE CAR (super_car) ═══════════
         FIX: Removed absolute-path mesh URI.
              Using solid geometry that works on all machines.
              Spawn Z = 0.4 (exactly wheel radius) so wheels rest on ground.
              Starting pose: x=-10, y=0, heading=0 (facing +X / east).
              Goal will be x=+10, y=0.
    ═══════════════════════════════════════════════ -->
    <model name="super_car">
      <pose>-10 0 0.4 0 0 0</pose>
      <static>false</static>

      <!-- Base body -->
      <link name="base_link">
        <inertial>
          <mass>800.0</mass>
          <inertia>
            <ixx>200.0</ixx><iyy>800.0</iyy><izz>900.0</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="body_col">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>4.5 2.0 0.8</size></box></geometry>
        </collision>
        <!-- Car body visual — silver box -->
        <visual name="body_vis">
          <pose>0 0 0.4 0 0 0</pose>
          <geometry><box><size>4.5 2.0 0.8</size></box></geometry>
          <material><ambient>0.75 0.75 0.75 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
        <!-- Cabin on top -->
        <visual name="cabin_vis">
          <pose>-0.3 0 1.05 0 0 0</pose>
          <geometry><box><size>2.2 1.7 0.6</size></box></geometry>
          <material><ambient>0.4 0.6 0.9 0.7</ambient><diffuse>0.4 0.6 0.9 0.7</diffuse></material>
        </visual>
      </link>

      <!-- Front-left steering pivot -->
      <link name="fl_steering_link">
        <pose>1.5 0.85 0 0 0 0</pose>
        <inertial><mass>0.1</mass>
          <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
        </inertial>
      </link>
      <joint name="fl_steer_j" type="revolute">
        <parent>base_link</parent><child>fl_steering_link</child>
        <pose>0 0 0 0 0 0</pose>
        <axis><xyz>0 0 1</xyz><limit><lower>-0.6</lower><upper>0.6</upper></limit></axis>
      </joint>

      <!-- Front-right steering pivot -->
      <link name="fr_steering_link">
        <pose>1.5 -0.85 0 0 0 0</pose>
        <inertial><mass>0.1</mass>
          <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
        </inertial>
      </link>
      <joint name="fr_steer_j" type="revolute">
        <parent>base_link</parent><child>fr_steering_link</child>
        <pose>0 0 0 0 0 0</pose>
        <axis><xyz>0 0 1</xyz><limit><lower>-0.6</lower><upper>0.6</upper></limit></axis>
      </joint>

      <!-- Front-left wheel -->
      <link name="fl_wheel">
        <pose>1.5 0.85 0 0 0 0</pose>
        <inertial><mass>15.0</mass>
          <inertia><ixx>0.4</ixx><iyy>0.7</iyy><izz>0.4</izz></inertia>
        </inertial>
        <collision name="c"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
      </link>
      <joint name="fl_j" type="revolute">
        <parent>fl_steering_link</parent><child>fl_wheel</child>
        <axis><xyz>0 1 0</xyz></axis>
      </joint>

      <!-- Front-right wheel -->
      <link name="fr_wheel">
        <pose>1.5 -0.85 0 0 0 0</pose>
        <inertial><mass>15.0</mass>
          <inertia><ixx>0.4</ixx><iyy>0.7</iyy><izz>0.4</izz></inertia>
        </inertial>
        <collision name="c"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
      </link>
      <joint name="fr_j" type="revolute">
        <parent>fr_steering_link</parent><child>fr_wheel</child>
        <axis><xyz>0 1 0</xyz></axis>
      </joint>

      <!-- Rear-left wheel -->
      <link name="rl_wheel">
        <pose>-1.5 0.85 0 0 0 0</pose>
        <inertial><mass>15.0</mass>
          <inertia><ixx>0.4</ixx><iyy>0.7</iyy><izz>0.4</izz></inertia>
        </inertial>
        <collision name="c"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
      </link>
      <joint name="rl_j" type="revolute">
        <parent>base_link</parent><child>rl_wheel</child>
        <pose relative_to="base_link">-1.5 0.85 0 0 0 0</pose>
        <axis><xyz>0 1 0</xyz></axis>
      </joint>

      <!-- Rear-right wheel -->
      <link name="rr_wheel">
        <pose>-1.5 -0.85 0 0 0 0</pose>
        <inertial><mass>15.0</mass>
          <inertia><ixx>0.4</ixx><iyy>0.7</iyy><izz>0.4</izz></inertia>
        </inertial>
        <collision name="c"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface>
        </collision>
        <visual name="v"><pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.4</radius><length>0.25</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient></material></visual>
      </link>
      <joint name="rr_j" type="revolute">
        <parent>base_link</parent><child>rr_wheel</child>
        <pose relative_to="base_link">-1.5 -0.85 0 0 0 0</pose>
        <axis><xyz>0 1 0</xyz></axis>
      </joint>

      <!-- LiDAR link -->
      <link name="lidar_link">
        <pose>0 0 1.5 0 0 0</pose>
        <inertial><mass>0.5</mass>
          <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
        </inertial>
        <visual name="v">
          <geometry><cylinder><radius>0.08</radius><length>0.12</length></cylinder></geometry>
          <material><ambient>0.8 0.1 0.1 1</ambient></material>
        </visual>
        <!--
          FIX: sensor type = "gpu_lidar" not "gpu_ray"
               gz:frame_id must match what we publish TF for = "lidar_link"
        -->
        <sensor name="lidar" type="gpu_lidar">
          <always_on>true</always_on>
          <update_rate>10</update_rate>
          <visualize>false</visualize>
          <topic>/scan</topic>
          <gz:frame_id>lidar_link</gz:frame_id>
          <lidar>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
              <vertical>
                <samples>1</samples>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.3</min>
              <max>15.0</max>
              <resolution>0.01</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </lidar>
        </sensor>
      </link>
      <joint name="lidar_joint" type="fixed">
        <parent>base_link</parent><child>lidar_link</child>
      </joint>

      <!-- ── Ackermann Steering Plugin ── -->
      <plugin filename="gz-sim-ackermann-steering-system"
              name="gz::sim::systems::AckermannSteering">
        <left_front_wheel_joint>fl_j</left_front_wheel_joint>
        <right_front_wheel_joint>fr_j</right_front_wheel_joint>
        <left_rear_wheel_joint>rl_j</left_rear_wheel_joint>
        <right_rear_wheel_joint>rr_j</right_rear_wheel_joint>
        <left_steering_joint>fl_steer_j</left_steering_joint>
        <right_steering_joint>fr_steer_j</right_steering_joint>
        <kingpin_width>1.7</kingpin_width>
        <wheel_base>3.0</wheel_base>
        <wheel_radius>0.4</wheel_radius>
        <max_steering_angle>0.55</max_steering_angle>
        <min_velocity>-2.0</min_velocity>
        <max_velocity>5.0</max_velocity>
        <min_acceleration>-4.0</min_acceleration>
        <max_acceleration>4.0</max_acceleration>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <odom_publish_frequency>30</odom_publish_frequency>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
      </plugin>

      <!-- ── Joint State Publisher Plugin ── -->
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher">
        <topic>/joint_states</topic>
      </plugin>

      <!-- ── Pose Publisher (for TF bridge) ── -->
      <plugin filename="gz-sim-pose-publisher-system"
              name="gz::sim::systems::PosePublisher">
        <publish_link_pose>true</publish_link_pose>
        <publish_collision_pose>false</publish_collision_pose>
        <publish_visual_pose>false</publish_visual_pose>
        <publish_nested_models>true</publish_nested_models>
        <use_pose_vector_msg>true</use_pose_vector_msg>
        <static_publisher>false</static_publisher>
        <update_frequency>30</update_frequency>
      </plugin>

    </model><!-- end super_car -->

    <!--
      ═══════════════════════════════════════════════════════════
        WALKING ACTORS
        FIX 1: Added <animation> block with the SAME .dae file
                as <skin>. Without <animation>, Gazebo interpolates
                position but plays no walking frames → blink/snap.
        FIX 2: Trajectories now move actors ACROSS the arena in
                genuine 2-D paths, not just back-and-forth on Y.
        FIX 3: Using the system walk.dae from Gazebo's built-in
                resource path so it works on any machine.
                Path: /usr/share/gazebo-*/media/models/walk.dae
                If that path is missing, we fall back to simple
                box actors (see note below).
      ═══════════════════════════════════════════════════════════
    -->

    <!-- Actor h1: crosses the car's main corridor diagonally -->
    <actor name="h1">
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>walk.dae</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>  <pose>-3  4  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>8</time>  <pose>-3 -4  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>16</time> <pose>-3  4  1.02  0 0  1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- Actor h2: crosses perpendicular to car path -->
    <actor name="h2">
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>walk.dae</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>  <pose>2   5  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>9</time>  <pose>2  -5  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>18</time> <pose>2   5  1.02  0 0  1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- Actor h3: L-shaped path around pillar -->
    <actor name="h3">
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>walk.dae</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>  <pose>-8 -3  1.02  0 0  0</pose></waypoint>
          <waypoint><time>10</time> <pose>-2 -3  1.02  0 0  0</pose></waypoint>
          <waypoint><time>18</time> <pose>-2  3  1.02  0 0  1.5708</pose></waypoint>
          <waypoint><time>28</time> <pose>-8  3  1.02  0 0  3.1416</pose></waypoint>
          <waypoint><time>36</time> <pose>-8 -3  1.02  0 0 -1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- Actor h4: cuts across diagonally near goal point -->
    <actor name="h4">
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>walk.dae</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>  <pose>5   4  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>8</time>  <pose>5  -4  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>16</time> <pose>5   4  1.02  0 0  1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- Actor h5: patrols along car's path directly -->
    <actor name="h5">
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>walk.dae</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walk">
          <waypoint><time>0</time>  <pose>0   3  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>6</time>  <pose>0  -3  1.02  0 0 -1.5708</pose></waypoint>
          <waypoint><time>12</time> <pose>0   3  1.02  0 0  1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- Actor h6: wide arc patrol -->
    <actor name="h6">
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walk">
        <filename>walk.dae</filename>
