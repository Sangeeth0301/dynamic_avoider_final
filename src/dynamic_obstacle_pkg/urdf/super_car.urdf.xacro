<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="super_car">
  <material name="silver">   <color rgba="1.0 0.4 0.0 1.0"/> </material>
  <material name="blue">     <color rgba="0.40 0.60 0.90 0.7"/> </material>
  <material name="red">      <color rgba="0.80 0.10 0.10 1.0"/> </material>
  <material name="dark">     <color rgba="0.10 0.10 0.10 1.0"/> </material>

  <link name="base_link">
    <visual>
      <geometry><box size="0.8 0.4 0.25"/></geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.05 0 0.2"/>
      <geometry><box size="0.35 0.3 0.15"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.8 0.4 0.25"/></geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <visual><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.15" length="0.06"/></geometry><material name="dark"/></visual>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/> <child link="left_wheel"/>
    <origin xyz="0 0.22 0"/> <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual><origin rpy="1.5708 0 0"/><geometry><cylinder radius="0.15" length="0.06"/></geometry><material name="dark"/></visual>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/> <child link="right_wheel"/>
    <origin xyz="0 -0.22 0"/> <axis xyz="0 1 0"/>
  </joint>

  <link name="caster">
    <visual><geometry><sphere radius="0.08"/></geometry><material name="dark"/></visual>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/> <child link="caster"/>
    <origin xyz="0.35 0 -0.05"/>
  </joint>

  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.08" length="0.12"/></geometry><material name="red"/></visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/> <child link="lidar_link"/>
    <origin xyz="0 0 0.3"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/> <child link="imu_link"/>
    <origin xyz="0 0 0"/>
  </joint>
</robot>